rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt'])
        && data.email is string && data.email.size() <= 255
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidRoutine(data) {
      return data.keys().hasAll(['title', 'time', 'level', 'createdAt', 'userId'])
        && data.title is string && data.title.size() <= 100
        && data.time is string && data.time.size() <= 50
        && data.level is string && data.level.size() <= 50
        && data.userId is string && data.userId == request.auth.uid
        && data.createdAt is timestamp;
    }

    // 1. Users Collection
    match /users/{userId} {
      // Users can read own profile
      allow get: if isSignedIn() && request.auth.uid == userId;

      // Allow users to create their own profile
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().email == request.auth.token.email;

      // Allow users to update their own profile
      allow update: if isSignedIn() 
        && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['level', 'equipment', 'goal', 'updatedAt'])
        && incoming().updatedAt == request.time;
        
      // 2. Routines Subcollection
      match /routines/{routineId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() 
          && request.auth.uid == userId
          && isValidId(routineId)
          && isValidRoutine(incoming())
          && incoming().createdAt == request.time;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
